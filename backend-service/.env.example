# PostgreSQL connection
# IMPORTANT: Change credentials before deploying to production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runthedev

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=change-me-to-a-strong-key

# Admin API key (for protected endpoints)
# IMPORTANT: Change this to a strong random value before deploying to production
ADMIN_API_KEY=change-me-to-a-strong-key

# Audit service integration
AUDIT_SERVICE_URL=http://127.0.0.1:8000
AUDIT_POLL_INTERVAL_SECONDS=10
AUDIT_HTTP_TIMEOUT_SECONDS=120

# Server
HOST=0.0.0.0
PORT=4000

# Logging (trace, debug, info, warn, error)
RUST_LOG=info

# Optional comma-separated extra allowed CORS origins (exact match)
# Example: CORS_EXTRA_ORIGINS=https://staging.runthe.dev,https://app.example.com
CORS_EXTRA_ORIGINS=
